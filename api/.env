# Common Variables
# ------------------------------
# The name of the project.

COMPOSE_PROJECT_NAME=servo_ai


# ------------------------------
# Redis Configuration
# ------------------------------

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=Luffy2025@
REDIS_USE_SSL=false
REDIS_DB=0       

# ------------------------------
# Celery 任务队列配置
# ------------------------------
# Celery消息代理URL（使用Redis作为broker）
# 格式：redis://:<密码>@<主机>:<端口>/<数据库号>
CELERY_BROKER_URL=redis://:Luffy2025@@127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://:Luffy2025@@127.0.0.1:6379/0

CELERY_TIMEZONE=Asia/Shanghai
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT='["json"]'
CELERY_RESULT_EXPIRES=3600


# Celery工作进程数量（默认1，根据CPU核心数调整）
CELERY_WORKER_AMOUNT=1

# 是否启用工作进程自动扩展（默认关闭）
CELERY_AUTO_SCALE=false
# 自动扩展时的最大工作进程数
CELERY_MAX_WORKERS=
# 自动扩展时的最小工作进程数
CELERY_MIN_WORKERS=

# Redis哨兵模式配置（高可用场景使用）
# 是否启用Redis哨兵模式
CELERY_USE_SENTINEL=false   
# 哨兵主节点名称 
CELERY_SENTINEL_MASTER_NAME= 
# 哨兵连接超时时间（秒）# 哨兵节点列表，格式：[('sentinel1', 26379), ('sentinel2', 26379)]
CELERY_SENTINEL_SOCKET_TIMEOUT=0.1  


# ------------------------------
# MySQL Configuration
# ------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=iot_platform
DB_USER=root
DB_PASSWORD=Luffy2025@

# ========== 日志配置 ==========
LOG_FILE=
LOG_FILE_MAX_SIZE=20
LOG_FILE_BACKUP_COUNT=5
LOG_DATEFORMAT=%Y-%m-%d %H:%M:%S
LOG_TZ=UTC
LOG_FORMAT=%(asctime)s,%(msecs)d %(levelname)-2s [%(filename)s:%(lineno)d] %(req_id)s %(message)s


# ========== 应用服务配置 ==========
DIFY_BASE_URL="http://xuntian-ai-sit.tclpv.com"
DIFY_API_KEY="app-FpC7jmVhoS90BTUSfCxsm0gG"
DIFY_TIMEOUT=300
DIDY_OCR_BASE_URL='https://xuntian-hw-dev.tclpv.com/'