# Common Variables
# ------------------------------
# The name of the project.

COMPOSE_PROJECT_NAME=servo_ai


# ------------------------------
# Redis Configuration
# ------------------------------

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=difyai123456
REDIS_USE_SSL=false
REDIS_DB=0

# ------------------------------
# Redis 连接配置 (Celery依赖)
# ------------------------------
REDIS_HOST=redis             
REDIS_PORT=6379             
REDIS_PASSWORD=difyai123456  
REDIS_DB=0                  
REDIS_USE_SSL=false         

# ------------------------------
# Celery 任务队列配置
# ------------------------------
# Celery消息代理URL（使用Redis作为broker）
# 格式：redis://:<密码>@<主机>:<端口>/<数据库号>
CELERY_BROKER_URL=redis://:difyai123456@redis:6379/0
CELERY_RESULT_BACKEND=redis://:difyai123456@redis:6379/0


# Celery工作进程数量（默认1，根据CPU核心数调整）
CELERY_WORKER_AMOUNT=1

# 是否启用工作进程自动扩展（默认关闭）
CELERY_AUTO_SCALE=false
# 自动扩展时的最大工作进程数
CELERY_MAX_WORKERS=
# 自动扩展时的最小工作进程数
CELERY_MIN_WORKERS=

# Redis哨兵模式配置（高可用场景使用）
# 是否启用Redis哨兵模式
CELERY_USE_SENTINEL=false   
# 哨兵主节点名称 
CELERY_SENTINEL_MASTER_NAME= 
# 哨兵连接超时时间（秒）# 哨兵节点列表，格式：[('sentinel1', 26379), ('sentinel2', 26379)]
CELERY_SENTINEL_SOCKET_TIMEOUT=0.1  